# ===================================
# Vaibhav Pharmacy WhatsApp Bot
# Environment Configuration
# ===================================

# WhatsApp Business Cloud API
# Get these from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# Webhook verification token (you choose this - any random string)
WEBHOOK_VERIFY_TOKEN=vaibhav_pharmacy_verify_2024

# Server config
PORT=3000

# Pharmacy info
PHARMACY_NAME=Vaibhav Pharmacy
PHARMACY_PHONE=+91XXXXXXXXXX
